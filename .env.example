# Meta Ads Copilot — Environment Variables
#
# Reporting auth is normally handled by social-cli:
#   social auth login
#
# Copy this file to .env and uncomment only the values your workflow needs.

# Default Meta ad account.
# Optional for reporting if social-cli already has a default account.
# Required for Graph API upload workflows.
# META_AD_ACCOUNT=act_123456789

# Meta Graph API token used by ad upload and account-performance lookup workflows.
# Required when using direct Graph API calls outside social-cli token management.
# FACEBOOK_ACCESS_TOKEN=EAAB...

# Meta Graph API token used by Pixel/CAPI scripts.
# Some Pixel/CAPI scripts can fall back to ~/.social-cli/config.json when supported.
# META_TOKEN=EAAB...
