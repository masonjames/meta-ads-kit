# Meta Ads Copilot — Environment Variables
#
# Copy this file to .env and uncomment only the values your workflow needs.
# The installed meta-ads CLI also loads ~/.hermes/envs/meta-ads/.env.
# Store real tokens in a secrets manager such as 1Password or your shell profile; never commit secrets.

# Meta Graph API access token used by meta-ads CLI and direct Graph API workflows.
# ACCESS_TOKEN=EAAB...

# Default Meta ad account for reporting and Graph API workflows.
# Include the act_ prefix.
# AD_ACCOUNT_ID=act_123456789

# Optional Business Manager ID for account/business-scoped workflows.
# BUSINESS_ID=123456789

# Optional CLI override if meta-ads is installed outside PATH.
# META_ADS_CLI=/absolute/path/to/meta-ads
